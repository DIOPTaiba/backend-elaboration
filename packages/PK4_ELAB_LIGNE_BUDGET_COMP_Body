create or replace PACKAGE BODY PK4_ELAB_LIGNE_BUDGET_COMP AS

--------------------------------------------------------------------------------
FUNCTION f_next_code RETURN varchar2 AS
    cursor c_code is select max(to_number(substr(LBUC_CODE, 5))) from TB_LIGNE_BUDGET_COMP;
    v_code varchar2(20);
    v_max number;
    begin
      open c_code;
      fetch c_code into v_max;
      close c_code;
      v_max:=nvl(v_max,0)+1;
      v_code:='LBUC' || lpad(v_max,6,'0');
      return v_code;
    END f_next_code;
--------------------------------------------------------------------------------

------------------------------------------------------------------------------------
PROCEDURE p_insertion(P_BUC_CODE out varchar2,
                        P_LBUC_SEC_ID VARCHAR,
                        P_LBUC_BUDC_CODE varchar2,
                        P_LBUC_CHAP_ID varchar2,
                        P_LBUC_NAT_ID number,
                        P_LBUC_CADE_CODE varchar2,
                        P_LBUC_SFIN_CODE varchar2,
                        P_LBUC_SFIN_CODE_NEW varchar2,
                        P_LBUC_BAILF_CODE number, /*code bailleur*/
                        P_LBUC_CP_1_PREC number,  /*CP de la version precedente du projet de budget*/
                        P_LBUC_CP_1 number,   /*CP de la version courante du projet de budget*/
                        P_LBUC_AE_ANT number, /*AE gestions anterieures hors CP deja budgetises*/
                        P_LBUC_AE_1_PREC number, /*AE de la version precedente du projet de budget*/
                        P_LBUC_AE_1 number, /*AE de la version courante du projet de budget*/
                        P_LBUC_FONCACT_ID varchar2,
                        p_etat out number,
                        p_erreur out varchar2) is

 cursor c_bud_comp is select cop_pro_id pro_id, cop_id,cop_cop_id, BUDC_VERS_CODE vers_code, PAPP_EXPB_CODE EXPB_CODE
                             from tb_budget_comp, tb_comp_prog, tb_pap_programme
                              where budc_cop_id=cop_id and budc_code=P_LBUC_BUDC_CODE
                              and budc_papp_ref=papp_ref;
 cursor c_chap is select CHAP_CODE, CC_DIF_ID DIF_ID from tb_chapitre, tb_chap_classe
                  where CHAP_ID=CC_CHAP_ID(+) and CHAP_ID=P_LBUC_CHAP_ID;


 l_budc c_bud_comp%rowtype;
 l_chap c_chap%rowtype;
 V_BUC_CODE varchar2(10);
 BEGIN
     /* p_etat:=0;
      p_erreur:='La mise à jour du projet de budget est verrouillée';
      return;

   if substr(P_LBUC_FONCACT_ID,1,5) not in ('SECTL', 'CGBUD') then
      p_etat:=0;
      p_erreur:='Privilèges insuffisants';
      return;
   end if;*/

   open c_bud_comp;
   fetch c_bud_comp into l_budc;
   if c_bud_comp%notfound then
      close c_bud_comp;
      p_etat := 0;
      p_erreur:='Le budget de la composante reference par '||P_LBUC_BUDC_CODE||' n''existe pas dans le systeme!';
      return;
   end if;
   close c_bud_comp;

   open c_chap;
   fetch c_chap into l_chap;
   if c_chap%notfound then
      close c_chap;
      p_etat := 0;
      p_erreur:='Le chapitre reference par '||P_LBUC_CHAP_ID||' n''existe pas dans le systeme ou bien il n''est lie a aucune classe!';
      return;
   end if;
   close c_chap;

   V_BUC_CODE := f_next_code();
   insert into TB_LIGNE_BUDGET_COMP(LBUC_CODE, LBUC_EXPB_CODE, LBUC_PRO_ID, LBUC_CHAP_ID, LBUC_CHAP_CODE, LBUC_DIF_ID, LBUC_SFIN_CODE, LBUC_BAILF_CODE,
                                    LBUC_NAT_ID, LBUC_BUDC_CODE,  LBUC_VERS_CODE, LBUC_CADE_CODE, LBUC_DATE, LBUC_COP_ID,LBUC_ACTION_ID,
                                    LBUC_CP_1_PREC, LBUC_CP_1, LBUC_AE_ANT, LBUC_AE_1_PREC, LBUC_AE_1, LBUC_FONCACT_ID,LBUC_SEC_ID,LBUC_SFIN_CODE_NEW)
                             values(V_BUC_CODE, l_budc.expb_code, l_budc.pro_id, P_LBUC_CHAP_ID, l_chap.chap_code, nvl(l_chap.dif_id,0), P_LBUC_SFIN_CODE, P_LBUC_BAILF_CODE,
                                    P_LBUC_NAT_ID, P_LBUC_BUDC_CODE, l_budc.vers_code, P_LBUC_CADE_CODE, sysdate, l_budc.cop_id,l_budc.cop_cop_id,
                                    P_LBUC_CP_1_PREC, P_LBUC_CP_1, P_LBUC_AE_ANT, P_LBUC_AE_1_PREC, P_LBUC_AE_1, P_LBUC_FONCACT_ID,P_LBUC_SEC_ID,P_LBUC_SFIN_CODE_NEW);
    p_etat := 1;
    P_BUC_CODE:=V_BUC_CODE;
    EXCEPTION
           when others then
                P_ETAT := 0;
                P_ERREUR  := Sqlerrm;
END p_insertion;
