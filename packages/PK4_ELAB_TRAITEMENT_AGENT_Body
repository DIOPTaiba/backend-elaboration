create or replace PACKAGE BODY PK4_ELAB_TRAITEMENT_AGENT AS

---------------------------------------------------------------------------------------
function f_next_id return number is
  cursor c_max is select max(TRTAG_ID) from tb_traitement_agent;
  v_max number;
begin
  open c_max;
  fetch c_max into v_max;
  close c_max;
  return nvl(v_max,0)+1;
end f_next_id;
---------------------------------------------------------------------------------------
function f_ptil_modifier(p_expb varchar, p_mat varchar2, p_acteur varchar2) return number is
/*cette fonction retourne 1 si un acteur peut modifier les traitements d'un agent, 0 sinon
 -- l'acteur doit avoir le privilege PPPB20*/
 cursor c_sec is select affag_sec_id from tb_affectation_agent
                 where affag_agt_mat=p_mat and affag_expb_code=p_expb;
 v_sec varchar2(10);
begin
 if fb3_verrou_sectoriel(p_acteur, p_mat)=0 then
    return 0;
 else
    return 1;
 end if;

 open c_sec;
 fetch c_sec into v_sec;
 close c_sec;

 return PK3_PRIVILEGE_PPPB.f_get_priv_sur_sec(p_expb, p_acteur, v_sec, null, 'PPPB20');

end f_ptil_modifier;
---------------------------------------------------------------------------------------
FUNCTION F_IS_MODIFIABLE(pexpb varchar2, p_sec varchar2) return number is
  --renvoie 1 si les traitements ou emplois ne peuvent etre  modifies, 0 sinon
  v_val number;
begin
  v_val:=1;
  return v_val;
end F_IS_MODIFIABLE;
