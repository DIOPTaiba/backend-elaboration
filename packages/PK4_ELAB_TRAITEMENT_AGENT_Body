procedure p_insert_trait_agent(p_trait out number,
                          p_expb varchar,
                          p_mat varchar2,
                          p_nat number,
                          p_mont number,
                          P_TEXTE_REF varchar2,
                          P_OBS varchar2,
                          p_acteur varchar2,
                          p_etat out number,
                          p_erreur out varchar2
                          ) is
 cursor c_verif is select TRTAG_ID from tb_traitement_agent
                    where TRTAG_EXPB_CODE=p_expb and TRTAG_NAT_ID=p_nat and TRTAG_AGT_MAT=p_mat;

 cursor c_rech is select affag_sec_id from tb_affectation_agent
                    where AFFAG_EXPB_CODE=p_expb and AFFAG_AGT_MAT=p_mat;

  v_verif number;
  v_id number;
  v_sec_id  varchar2(10);

begin
  /*p_etat:=0;
  p_erreur:='La mise à jour des traitements des agents est verrouillée.';
  return;*/

  if p_expb is null then
     p_etat:=0;
     p_erreur:='L''exercice budgetaire doit être renseigné.';
     return;
  end if;

  if p_mat is null then
     p_etat:=0;
     p_erreur:='Le matricule de l''agent doit être renseigné.';
     return;
  end if;

  if p_mont is null then
     p_etat:=0;
     p_erreur:='Le montant alloue pour la nature de dépense doit être renseigné.';
     return;
  end if;

  if p_nat is null then
     p_etat:=0;
     p_erreur:='La référence de la nature économique de la dépense doit être renseignée.';
     return;
  end if;

  open c_verif;
  fetch c_verif into v_verif;
  if c_verif%found then
     close c_verif;
     p_etat:=0;
     p_erreur:='Un traitement existe dèjà sur l''agent et la nature de dépense. L''identifiant est le numero '||v_verif||'. Vous ne pouvez pas faire une nouvelle insertion.';
     return;
  end if;
  close c_verif;

  open c_rech;
  fetch c_rech into v_sec_id;
  if c_rech%notfound then
     close c_rech;
     p_etat:=0;
     p_erreur:='L''agent '||p_mat||' n''est affecté a aucune section sur l''exercice '||substr(p_expb,1,4)||'.';
     return;
  end if;
  close c_rech;

  if f_ptil_modifier(p_expb,p_mat,p_acteur)<>1 then
     p_etat:=0;
     p_erreur:='Vos privileges ne suffisent pas pour la mise à jour du traitement de l''agent de matricule '||p_mat||'.';
     return;
  end if;

  if f_is_modifiable(p_expb,v_sec_id)<>1 then
     p_etat:=0;
     p_erreur:='Le statut actuel du projet de budget ne permet pas la mise à jour des traitements des agents.';
     return;
  end if;

  v_id:=f_next_id;
  insert into tb_traitement_agent (TRTAG_ID,TRTAG_AGT_MAT, TRTAG_EXPB_CODE,TRTAG_NAT_ID, TRTAG_MONT,
                                     TRTAG_TEXTE_REF, TRTAG_OBS, TRTAG_FONCACT_ID_SAI, TRTAG_DATE_SAI)
                               values(v_id, p_mat, p_expb, p_nat, p_mont,
                                      P_TEXTE_REF, P_OBS, p_acteur, sysdate);
  p_etat:=1;
  p_trait:=v_id;
  Exception
    when others then
          p_etat:=0;
          p_erreur:=sqlerrm;
          p_trait:=null;
end p_insert_trait_agent;
--- -------------------------------------------------------------------------------------
procedure p_maj_trait_agent(p_trait number,
                          p_mont number,
                          P_TEXTE_REF varchar2,
                          P_OBS varchar2,
                          p_acteur varchar2,
                          p_etat out number,
                          p_erreur out varchar2
                          ) is

 cursor c_verif is select AFFAG_EXPB_CODE, AFFAG_SEC_ID, AFFAG_AGT_MAT
                    from tb_traitement_agent, tb_affectation_agent
                    where AFFAG_EXPB_CODE=TRTAG_EXPB_CODE
                    and AFFAG_AGT_MAT=TRTAG_AGT_MAT
                    and TRTAG_ID=p_trait;

  v_expb varchar2(10);
  v_sec_id  varchar2(10);
  v_mat varchar2(10);

begin
  /*p_etat:=0;
  p_erreur:='La mise à jour des traitements des agents est verrouillée.';
  return;*/

  if p_mont is null then
     p_etat:=0;
     p_erreur:='Le montant alloué pour la nature de depense doit etre renseigné.';
     return;
  end if;

  open c_verif;
  fetch c_verif into v_expb, v_sec_id, v_mat;
  if c_verif%notfound then
     close c_verif;
     p_etat:=0;
     p_erreur:='Le traitement referencé par '||p_trait||' est, inconnu du système.';
     return;
  end if;
  close c_verif;

  if F_PTIL_MODIFIER(v_expb,v_sec_id,p_acteur)<>1 then
     p_etat:=0;
     p_erreur:='Vos privilèges ne suffisent pas pour la mise a jour du traitement de l''agent '||v_mat||'.';
     return;
  end if;

  if f_is_modifiable(v_expb,v_sec_id)<>1 then
     p_etat:=0;
     p_erreur:='Le statut actuel du projet de budget ne permet pas la mise a jour des traitements des agents.';
     return;
  end if;

  update tb_traitement_agent set TRTAG_MONT=p_mont, TRTAG_TEXTE_REF=P_TEXTE_REF, TRTAG_OBS=P_OBS,
                                    TRTAG_FONCACT_ID_MODIF=p_acteur, TRTAG_DATE_MODIF=sysdate
                                    where TRTAG_ID=p_trait;

  p_etat:=1;
  Exception
    when others then
          p_etat:=0;
          p_erreur:=sqlerrm;
end p_maj_trait_agent;

