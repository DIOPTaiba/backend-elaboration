procedure p_insert_trait_profil(p_trait out number,
                          p_expb varchar,
                          p_profil varchar2,
                          p_nat number,
                          p_mont number,
                          P_TEXTE_REF varchar2,
                          P_OBS varchar2,
                          p_acteur varchar2,
                          p_etat out number,
                          p_erreur out varchar2
                          ) is
 cursor c_verif is select TRTAG_ID from tb_traitement_agent
                    where TRTAG_EXPB_CODE=p_expb and TRTAG_NAT_ID=p_nat and TRTAG_PFLAG_ID=p_profil;

 cursor c_rech is select pflag_sec_id, pflag_pro_id from tb_profil_agent
                    where PFLAG_EXPB_CODE=p_expb and PFLAG_ID=p_profil;

  v_verif number;
  v_id number;
  v_sec_id  varchar2(10);
  v_pro_id varchar2(10);

begin
  p_etat:=0;
  p_erreur:='La mise à jour des traitements des agents est verrouillée.';
  return;

  if p_expb is null then
     p_etat:=0;
     p_erreur:='L''exercice budgetaire doit etre renseigne.';
     return;
  end if;

  if p_profil is null then
     p_etat:=0;
     p_erreur:='Le profil d''agent recherche doit etre renseigne.';
     return;
  end if;

  if p_nat is null then
     p_etat:=0;
     p_erreur:='La reference de la nature economique de la depense doit etre renseignee.';
     return;
  end if;

  if p_mont is null then
     p_etat:=0;
     p_erreur:='Le montant alloue pour la nature de depense doit etre renseigne.';
     return;
  end if;

  open c_verif;
  fetch c_verif into v_verif;
  if c_verif%found then
     close c_verif;
     p_etat:=0;
     p_erreur:='Un traitement existe deja sur le profil et la nature de depense. L''identifiant est le numero '||v_verif||'. Vous ne pouvez pas faire une nouvelle insertion.';
     return;
  end if;
  close c_verif;

  open c_rech;
  fetch c_rech into v_sec_id, v_pro_id;
  if c_rech%notfound then
     close c_rech;
     p_etat:=0;
     p_erreur:='Le profil '||p_profil||' n''existe pas dans l''exercice '||substr(p_expb,1,4)||'.';
     return;
  end if;
  close c_rech;

  if pk3_affectation_agent.F_PTIL_AFF_DANS_PROG(p_expb,v_pro_id,p_acteur)<>1 then
     p_etat:=0;
     p_erreur:='Vos privileges ne suffisent pas pour la mise a jour du traitement du profil '||p_profil||'.';
     return;
  end if;

  if f_is_modifiable(p_expb,v_sec_id)<>1 then
     p_etat:=0;
     p_erreur:='Le statut actuel du projet de budget ne permet pas la mise a jour des traitements des profils.';
     return;
  end if;

  v_id:=f_next_id;
  insert into tb_traitement_agent (TRTAG_ID, TRTAG_PFLAG_ID, TRTAG_EXPB_CODE,TRTAG_NAT_ID, TRTAG_MONT,
                                     TRTAG_TEXTE_REF, TRTAG_OBS, TRTAG_FONCACT_ID_SAI, TRTAG_DATE_SAI)
                               values(v_id, p_profil, p_expb, p_nat, p_mont,
                                      P_TEXTE_REF, P_OBS, p_acteur, sysdate);

  p_etat:=1;
  p_trait:=v_id;
  Exception
    when others then
          p_etat:=0;
          p_erreur:=sqlerrm;
          p_trait:=null;
end p_insert_trait_profil;
