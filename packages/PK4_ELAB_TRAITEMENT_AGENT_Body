                                    TRTAG_FONCACT_ID_MODIF=p_acteur, TRTAG_DATE_MODIF=sysdate
                                    where TRTAG_ID=p_trait;

  p_etat:=1;
  Exception
    when others then
          p_etat:=0;
          p_erreur:=sqlerrm;
end p_maj_trait_profil;
