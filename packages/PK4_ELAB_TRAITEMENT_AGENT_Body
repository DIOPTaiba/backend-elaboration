procedure p_maj_trait_profil(p_trait number,
                          p_mont number,
                          P_TEXTE_REF varchar2,
                          P_OBS varchar2,
                          p_acteur varchar2,
                          p_etat out number,
                          p_erreur out varchar2
                          ) is

 cursor c_verif is select TRTAG_EXPB_CODE, PFLAG_SEC_ID, PFLAG_PRO_ID, PFLAG_ID
                    from tb_traitement_agent, tb_profil_agent
                    where TRTAG_PFLAG_ID=PFLAG_ID and TRTAG_EXPB_CODE=PFLAG_EXPB_CODE
                    and TRTAG_ID=p_trait;

  v_expb varchar2(10);
  v_sec_id  varchar2(10);
  v_pro_id varchar2(10);
  v_profil varchar2(10);

begin
  p_etat:=0;
  p_erreur:='La mise à jour des traitements des agents est verrouillée.';
  return;

  if p_mont is null then
     p_etat:=0;
     p_erreur:='Le montant alloue pour la nature de depense doit etre renseigne.';
     return;
  end if;

  open c_verif;
  fetch c_verif into v_expb, v_sec_id, v_pro_id, v_profil;
  if c_verif%notfound then
     close c_verif;
     p_etat:=0;
     p_erreur:='Le traitement reference par '||p_trait||' est, inconnu du systeme, oubien il ne correspond pas a celui d''un profil d''agent.';
     return;
  end if;
  close c_verif;

