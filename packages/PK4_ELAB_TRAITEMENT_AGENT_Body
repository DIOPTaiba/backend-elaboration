procedure P_DESC_AGENT(p_mat varchar2, p_nom out varchar2, p_prenom out varchar2, p_emploi out number) is
  cursor c_agent is select agt_nom, agt_prenoms, agt_empag_id from tb_agent where agt_mat=p_mat;

begin
  open c_agent;
  fetch c_agent into p_nom,p_prenom,p_emploi;
  close c_agent;
end P_DESC_AGENT;
--- -------------------------------------------------------------------------------------
procedure p_maj_par_nat_eco(p_expb varchar,
                          p_sec varchar2,
                          p_mat varchar2,
                          p_profil number,
                          p_nat number,
                          p_mont number,
                          P_TEXTE_REF varchar2,
                          P_OBS varchar2,
                          p_acteur varchar2,
                          p_etat out number,
                          p_erreur out varchar2
                          ) is
  cursor c_verif1 is select TRTAG_ID from tb_traitement_agent
                    where TRTAG_EXPB_CODE=p_expb and TRTAG_NAT_ID=p_nat and TRTAG_AGT_MAT=p_mat;

  cursor c_verif2 is select TRTAG_ID from tb_traitement_agent
                    where TRTAG_EXPB_CODE=p_expb and TRTAG_NAT_ID=p_nat and TRTAG_PFLAG_ID=p_profil;

  v_verif number;
  v_id number;
  v_op varchar2(1); --M=modifier, I=inserer
begin
 /* p_etat:=0;
  p_erreur:='La mise à jour des traitements des agents est verrouillée.';
  return;*/

  if p_expb is null then
     p_etat:=0;
     p_erreur:='L''exercice budgetaire doit etre renseigne.';
     return;
  end if;

  if p_mat is null then
     p_etat:=0;
     p_erreur:='Le matricule de l''agent doit etre renseigne.';
     return;
  end if;

  if p_mont is null then
     p_etat:=0;
     p_erreur:='Le montant alloue pour la nature de depense doit etre renseigne.';
     return;
  end if;

  if p_nat is null then
     p_etat:=0;
     p_erreur:='La reference de la nature economique de la depense doit etre renseignee.';
     return;
  end if;

  if p_mat is not null and f_ptil_modifier(p_expb,p_mat,p_acteur)<>1 then
     p_etat:=0;
     p_erreur:='Vos privileges ne suffisent pas pour la mise a jour du traitement de l''agent de matricule '||p_mat||'.';
     return;
  end if;

  if f_is_modifiable(p_expb,p_sec)<>1 then
     p_etat:=0;
     p_erreur:='Le statut actuel du projet de budget ne permet pas la mise a jour des traitements des agents.';
     return;
  end if;

  if p_mat is null then
     open c_verif1;
     fetch c_verif1 into v_verif;
     if c_verif1%notfound then --pour faire une insertion
       v_op:='I';
     else   --pour faire une mise a jour
       v_op:='M';
     end if;
     close c_verif1;
  elsif p_profil is null then
     open c_verif2;
     fetch c_verif2 into v_verif;
     if c_verif2%notfound then --pour faire une insertion
       v_op:='I';
     else    --pour faire une mise a jour
       v_op:='M';
     end if;
     close c_verif2;
  end if;

  if v_op='I' then
     v_id:=f_next_id;
     insert into tb_traitement_agent (TRTAG_ID,TRTAG_AGT_MAT, TRTAG_PFLAG_ID, TRTAG_EXPB_CODE,TRTAG_NAT_ID, TRTAG_MONT,
                                     TRTAG_TEXTE_REF, TRTAG_OBS, TRTAG_FONCACT_ID_SAI, TRTAG_DATE_SAI)
                               values(v_id, p_mat, p_profil, p_expb, p_nat, p_mont,
                                      P_TEXTE_REF, P_OBS, p_acteur, sysdate);
  elsif v_op='M' then  --faire une mise a jour
     update tb_traitement_agent set TRTAG_MONT=p_mont, TRTAG_TEXTE_REF=P_TEXTE_REF, TRTAG_OBS=P_OBS,
                                    TRTAG_FONCACT_ID_MODIF=p_acteur, TRTAG_DATE_MODIF=sysdate
                                    where TRTAG_ID=v_verif;
  end if;

  p_etat:=1;

  Exception
    when others then
          p_etat:=0;
          p_erreur:=sqlerrm;
end p_maj_par_nat_eco;
