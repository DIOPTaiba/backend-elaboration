PROCEDURE P_UPADTE_AFFEC(P_EXPB_CODE varchar2,
                         P_MAT varchar2,
                         P_CHAP_ID varchar2,
                         P_CHAP_ID_PREC varchar2,
                         p_SEC_ID varchar2,
                         P_SEC_ID_PREC varchar2,
                         P_TEXTE_REF varchar2,
                         P_OBS varchar2,
                         P_FONCID_MODIF varchar2,
                         P_AFFEC_TYP varchar2,
                         P_ETAT OUT NUMBER,
                         P_ERREUR OUT VARCHAR2) IS
    V_TEXTE_REF_CHAP VARCHAR2(100 BYTE);
    V_OBS_CHAP VARCHAR2(4000 BYTE);
    V_TEXTE_REF_SEC VARCHAR2(100 BYTE);
    V_OBS_SEC VARCHAR2(4000 BYTE);
BEGIN
    P_ETAT := 1;
     IF P_AFFEC_TYP='C' THEN
         V_TEXTE_REF_CHAP := P_TEXTE_REF;
         V_OBS_CHAP := P_OBS;
     ELSE
        V_TEXTE_REF_SEC := P_TEXTE_REF;
         V_OBS_SEC := P_OBS;
     END IF;
  UPDATE TB_AFFECTATION_AGENT
  set AFFAG_CHAP_ID=P_CHAP_ID, AFFAG_CHAP_ID_PREC=P_CHAP_ID_PREC,
      AFFAG_SEC_ID=p_SEC_ID, AFFAG_SEC_ID_PREC=P_SEC_ID_PREC,
      AFFAG_TEXTE_REF_CHAP=V_TEXTE_REF_CHAP, AFFAG_OBS_CHAP=V_OBS_CHAP,
      AFFAG_TEXTE_REF_SEC=V_TEXTE_REF_SEC, AFFAG_OBS_SEC=V_OBS_SEC,
      AFFAG_FONCACT_ID_MODIF=P_FONCID_MODIF, AFFAG_DATE_MODIF=sysdate
  where AFFAG_EXPB_CODE=P_EXPB_CODE and AFFAG_AGT_MAT=P_MAT;
EXCEPTION
    when others then
       P_ETAT := 0;
       P_ERREUR:=SQLERRM;
END P_UPADTE_AFFEC;

