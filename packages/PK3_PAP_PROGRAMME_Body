procedure p_insert_pap(P_PAPP_REF out varchar2,
                      P_DPPD_REF varchar2,
                      P_VERS_CODE varchar2,
                      P_PRO_ID varchar2,
                      p_expb_code varchar2,
                      p_FONCACT_ID varchar2,
                      p_etat out number,
                      p_erreur out varchar2) is
   /*version plus complete*/

  cursor c_verif is select dppd_sec_id from tb_dppd
                 where dppd_ref=p_dppd_ref and dppd_expb_code=p_expb_code;

v_PAPP_REF varchar2(10);
v_rpapp_code varchar2(10);
v_sec_id varchar2(10);
begin
  open c_verif;
  fetch c_verif into v_sec_id;
  if c_verif%notfound then
     p_etat:=0;
     p_erreur:='La reference du DPPD n''est pas valide.' ;
     return;
  end if;

         --insertion du dppd
  v_papp_ref:=F_NEXT_CODE(p_EXPB_CODE);
  insert into tb_pap_programme(papp_ref, papp_vers_code, papp_sec_id, papp_stat_cod,
                               papp_pro_id, papp_dppd_ref, papp_expb_code,
                               papp_foncact_id, papp_date)
                    values(v_papp_ref, p_vers_code, v_sec_id, 'PAPP_0I',
                    p_pro_id, p_dppd_ref, p_expb_code,
                    p_foncact_id, sysdate);

  --inserer la revision
  p_insert_revision(v_papp_ref, P_VERS_CODE, 'PAP Programme nouvellement cree',
                    p_FONCACT_ID, v_rpapp_code, p_etat, p_erreur);
  if p_etat=0 then
     return;
  end if;

  --mettre a jour la revision du PAPP
  update tb_pap_programme set papp_rpapp_code=v_rpapp_code where papp_ref=v_PAPP_REF;

  --insertion de la position du dppd
 /* insert into tb_pos_dppd (PDPPD_NUM, PDPPD_DPPD_REF, PDPPD_STAT_COD, PDPPD_VERS_CODE,
                           PDPPD_RDPPD_CODE, PDPPD_FONCACT_ID, PDPPD_DATE)
                   values (PDPPD_NUM_SEQ.NEXTVAL, v_DPPD_REF, 'DPPD_0I', P_VERS_CODE,
                           v_rdppd_code, p_FONCACT_ID, sysdate);  */

  p_etat:=1;
  P_PAPP_REF:=v_PAPP_REF;
  exception
    when others then
    rollback;
    p_etat:=0;
    p_erreur:=SQLERRM;
    P_PAPP_REF:=null;
end p_insert_pap;
------------------------------------------------------------------------------------------------
procedure p_insert_revision(P_PAPP varchar2,
                            P_VERS_CODE varchar2,
                            p_motif varchar2,
                            p_FONCACT_ID varchar2,
                            P_RPAPP out varchar2,
                            p_etat out number,
                            p_erreur out varchar2) is

   cursor c_verif_papp is select papp_pro_id from tb_pap_programme where papp_ref=p_papp;

   V_PRO_ID varchar2(10);
   v_RPAPP varchar2(10);
begin
  open c_verif_papp;
  fetch c_verif_papp into v_pro_id;
  if c_verif_papp%notfound then
     close c_verif_papp;
     p_etat:=0;
     p_erreur:='La reference du PAPP ('||p_papp||') n''est pas valide';
     return;
  end if;

          --insertion de la revision du papp
  v_rpapp:=F_NEXT_REV_PAPP(p_vers_CODE);
  if  v_rpapp is null then
     p_etat:=0;
     p_erreur:='La version de la section n''est pas correcte et ne peut etre revisee.';
     return;
  end if;

  insert into tb_revision_papp (RPAPP_CODE, RPAPP_VERS_CODE, RPAPP_PRO_ID, rpapp_papp_ref,
                               RPAPP_MOTIF, RPAPP_FONCACT_ID, RPAPP_DATE)
               values (v_RPAPP, P_VERS_CODE, V_PRO_ID, p_papp,
                       p_motif, p_FONCACT_ID, sysdate);

  p_etat:=1;
  P_RPAPP:=v_RPAPP;
  exception
    when others then
    rollback;
    p_etat:=0;
    p_erreur:=SQLERRM;
    P_RPAPP:=null;
end p_insert_revision;
