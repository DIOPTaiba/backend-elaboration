  PROCEDURE p_insertion(p_papp_ref out tb_pap_programme.papp_ref%TYPE, p_papp_vers_code in tb_pap_programme.papp_vers_code%TYPE,
            p_papp_sec_id in tb_pap_programme.papp_sec_id%TYPE,
            p_papp_pro_id in tb_pap_programme.papp_pro_id%TYPE,
            p_papp_dppd_ref in tb_pap_programme.papp_dppd_ref%TYPE,
            p_papp_expb_code in tb_pap_programme.papp_expb_code%TYPE,
            p_papp_foncact_id in tb_pap_programme.papp_foncact_id%TYPE,
            p_etat out boolean, p_erreur out varchar2) AS

            -- cursor pour recuperer la reference de la version globale
            cursor c_version_sec is select vers_verg_code from tb_version_sec
            where vers_code = p_papp_vers_code;
            v_vers_verg_code varchar2(10);

            -------------  cursor pour recuperer le numero de version et la reference de l'exercice a partir de la version globale
            cursor c_version_globale(p_verg_code varchar2) is select verg_num, verg_expb_code from tb_version_globale
            where verg_code = p_verg_code;
            v_verg_num number(1);
            v_verg_expb_code varchar2(10);
            v_verg_num_prec number(1);

            ---------- recuperation de la version globale precedente
            cursor c_version_globale_prec(p_verg_expb_code varchar2, p_verg_num number) is select verg_code from tb_version_globale
            where verg_expb_code = p_verg_expb_code
            and verg_num = p_verg_num;
            v_verg_code_prec varchar2(10);

            --------- recuperation de la version ministerielle precente
            cursor c_version_sec_prec(p_verg_code varchar2) is select vers_code from tb_version_sec
            where vers_verg_code = p_verg_code
            and vers_sec_id = p_papp_sec_id;
            v_vers_code_prec varchar2(10);

            ------------- recuperation du papa_programme precedent
            cursor c_pap_programme_prec(p_papp_vers_code varchar2, p_prod_id varchar2) is select papp_ref
            from tb_pap_programme
            where papp_vers_code = p_papp_vers_code
            and papp_pro_id = p_prod_id;
            p_papp_ref_prec varchar2(10);

           ------------- recuperation des resultats attendus precedents
            cursor c_result_attendus_prec(p_papp_ref varchar2) is select resa_code, resa_obj_code, resa_foncact_id
            from tb_result_attendus where resa_papp_ref = p_papp_ref;
            p_resa_code varchar2(10);
            v_new_resa_code varchar2(10);
            p_resa_obj_code varchar2(10);
            p_resa_foncact_id varchar2(10);

            ---------------- recuperation des objectifs specifique du programme au cas ou nous somme sur la version preliminaire du budget
            cursor c_objectif_specif is select obj_code from tb_objectif where obj_tob_id = 'OBS'
                   and obj_pro_id = p_papp_pro_id;
            p_obj_codeOBS varchar2(10);

            ------------------  recuperation des indicateurs de resultat d'un objectif global
            cursor c_indicateur_obj_specif(param_obj_code varchar2) is select ind_code from tb_indicateur where ind_obj_code = param_obj_code;
            p_ind_codeOBS varchar2(10);

            ------------- recuperation des projection_resultats precedentes
            cursor c_projection_resultats_prec(p_pres_resa_code varchar2) is select pres_obj_code, pres_ind_code, pres_val_1,
            pres_val_2, pres_val_3, pres_struc_id, pres_expb_code, pres_val_ref, pres_foncact_id
            from tb_projection_resultats where
            pres_resa_code = p_pres_resa_code;

            p_pres_code varchar2(10);
            p_pers_obj_code varchar2(10);
            p_pers_ind_code varchar2(10);
            p_pers_val_1 NUMBER(15);
            p_pers_val_2 NUMBER(15);
            p_pers_val_3 NUMBER(15);
            p_pers_struc_id varchar2(10);
            p_pers_expb_code varchar2(10);
            p_pers_val_ref NUMBER(15);
            p_pers_foncat_id varchar2(10);

            --------------------------------- recuperation des TB_BUDGET_COMP precedent
            cursor c_budget_comp_prec(p_papp_ref varchar2) is select BUDC_CODE, BUDC_VERS_CODE,
            BUDC_COP_ID, BUDC_FONCACT_ID from TB_BUDGET_COMP where BUDC_PAPP_REF = p_papp_ref;
