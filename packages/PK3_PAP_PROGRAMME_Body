                                     and tp.papp_stat_cod not in ('PAPP_2V', 'PAPP_3V');
v_papp_ref tb_pap_programme.papp_ref%TYPE;
v_papp_vers_code tb_pap_programme.papp_ref%TYPE;
v_papp_sec_id tb_pap_programme.papp_ref%TYPE;
v_papp_pro_id tb_pap_programme.papp_ref%TYPE;
v_papp_foncact_id tb_pap_programme.papp_ref%TYPE;
v_papp_expb_code tb_budget_comp.budc_expb_code%TYPE;
P_NEW__BUDC_CODE tb_budget_comp.budc_code%TYPE;
cursor c_all_source_fin is select sfin_code from tb_source_fin;
/* cursor c_categ_depense_prg is select CADE_CODE from tb_categorie_depense where CADE_PROG = 'O'; */
cursor c_categ_depense_prg is
       select CADE_CODE from tb_categorie_depense
       where CADE_COMP2 =1;
v_cade_code varchar2(8);
p_LPCO_SFIN_CODE varchar(10);
p_new_LPCO_CODE tb_ligne_projection_comp.lpco_code%type;
BEGIN
  p_etat := true;
  p_erreur := '';

  open c_verif_versionMin_enCours;
  fetch c_verif_versionMin_enCours into v_papp_ref, v_papp_vers_code, v_papp_sec_id, v_papp_pro_id, v_papp_foncact_id,v_papp_expb_code;
  if (v_papp_ref is not null) then
    pk3_budget_comp.p_insertion(P_NEW__BUDC_CODE,
                                v_papp_vers_code,
                                v_papp_ref,
                                'BUDC_1S',
                                p_COP_ID,
                                v_papp_foncact_id,
                                v_papp_expb_code,
                                p_etat,
                                p_erreur);
    if(p_etat = true) then
      if p_COP_PPTIP_ID is null then
        p_LPCO_SFIN_CODE := 'TRE';
        open c_categ_depense_prg;
        loop
          fetch c_categ_depense_prg into v_cade_code;
          exit when c_categ_depense_prg%notfound or P_ETAT=false;
          pk3_ligne_projection_comp.p_insertion(p_new_LPCO_CODE,
                                                v_cade_code,
                                                0, 0, 0,
                                                P_NEW__BUDC_CODE,
                                                v_papp_foncact_id,
                                                p_LPCO_SFIN_CODE,
                                                p_COP_ID,
                                                p_etat,
                                                p_erreur);
          if (p_etat != true) then
            p_erreur := 'Erreur lors de l''insertion des lignes de projections de la version initiale';
            p_etat := false;
            return;
          end if;
        end loop;
        close c_categ_depense_prg;
      else
        open c_all_source_fin;
        loop
          fetch c_all_source_fin into p_LPCO_SFIN_CODE;
          exit when c_all_source_fin%notfound;
          open c_categ_depense_prg;
          loop
            fetch c_categ_depense_prg into v_cade_code;
            exit when c_categ_depense_prg%notfound or P_ETAT=false;
            pk3_ligne_projection_comp.p_insertion(p_new_LPCO_CODE,
                                                  v_cade_code,
                                                  0, 0, 0,
                                                  P_NEW__BUDC_CODE,
                                                  v_papp_foncact_id,
                                                  p_LPCO_SFIN_CODE,
                                                  p_COP_ID,
                                                  p_etat,
                                                  p_erreur);
            if (p_etat != true) then
              p_erreur := 'Erreur lors de l''insertion des lignes de projections de la version initiale';
              p_etat := false;
              return;
            end if;
          end loop;
          close c_categ_depense_prg;
        end loop;
        close c_all_source_fin;
      end if;
      --------------------------- insertion dans tb_ligne_budget_comp
    else
      p_erreur := 'Erreur lors de l''insertion des conteneurs budget_comp de la version initiale';
      p_etat := false;
      return;
    end if;
  else
    p_etat := true;
    p_erreur := '';
  end if;
  close c_verif_versionMin_enCours;
end p_prise_en_compte_activite;
---------------------------------------------------------------------------------------------------------------------------
END PK3_PAP_PROGRAMME;

