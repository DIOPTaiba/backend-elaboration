create or replace PACKAGE BODY PK3_PAP_PROGRAMME AS
  FUNCTION f_next_code RETURN varchar2 AS
    --  a  partir de la version ministerielle retrouver EXPB_EXE dans la table tb_exercice_projet_bud
    cursor c_code is select max(substr(papp_ref, 5)) from tb_pap_programme;
    v_code varchar2(10);
    v_max number;
    begin
      open c_code;
      fetch c_code into v_max;
      close c_code;
      v_max:=nvl(v_max,0)+1;
      v_code:='PAP-'||lpad(v_max,4,'0');
      return v_code;
  END f_next_code;
-----------------------------------------------------------------------------------------------------------
FUNCTION f_next_code (p_expb_code varchar2) RETURN varchar2 is
    --  a  partir de la version ministerielle retrouver EXPB_EXE dans la table tb_exercice_projet_bud
  CURSOR c_code is select max(to_number(substr(PAPP_REF, 7))) from tb_pap_programme
              where substr(papp_ref,1,6)='PAPP'||substr(P_EXPB_CODE,3,2);
--    cursor c_code is select max(substr(papp_ref, 5)) from tb_pap_programme;
    v_code varchar2(10);
    v_max number;
    begin
      open c_code;
      fetch c_code into v_max;
      close c_code;
      v_max:=nvl(v_max,0)+1;
      v_code:='PAPP'||substr(P_EXPB_CODE,3,2)||lpad(v_max,4,'0');
      return v_code;
  END f_next_code;
  ----------------------------------------------------------------------------------------------------
function F_NEXT_REV_PAPP(p_vers varchar2) return varchar2 is
  cursor c_verif is select 'X' from tb_version_sec where vers_code=p_vers;
  cursor c_rev_papp is select max(to_number(substr(rpapp_code,8))) from tb_revision_papp
         where rpapp_vers_code=p_vers;
  v_max number;
  v_verif varchar2(1);
  begin
    if p_vers is null then
       return null;
    end if;

    open c_verif;
    fetch c_verif into v_verif;
    if c_verif%notfound then
       close c_verif;
       return null;
    else
       close c_verif;
       open c_rev_papp;
       fetch c_rev_papp into v_max;
       close c_rev_papp;
       v_max:=nvl(v_max,0)+1;
       return p_vers||lpad(v_max,3,'0');
     end if;
  end;
