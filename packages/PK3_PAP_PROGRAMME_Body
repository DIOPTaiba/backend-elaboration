PROCEDURE p_evol_credits_saisie(p_version_sec varchar2,
                           p_prog varchar2,
                           p_categ varchar2,
                           p_mont_n1 out number,
                           p_mont_n2 out number,
                           p_mont_n3 out number) is
 /*cette procedure recupere les projections enregistrees dans toutes les composantes du programme,
  pour une categorie de depense et version donnees*/

  cursor c_mont_annee is select sum(lbuc_cp_1) mont_1
                   from tb_ligne_budget_comp, tb_budget_comp, tb_pap_programme
                   where lbuc_budc_code=budc_code and lbuc_cade_code=p_categ
                   and budc_papp_ref=papp_ref and papp_vers_code=p_version_sec
                   and papp_pro_id=p_prog;

  cursor c_mont is select sum(lpco_mont_2) mont_2,
                          sum(lpco_mont_3) mont_3
                   from tb_ligne_projection_comp, tb_budget_comp, tb_pap_programme
                   where lpco_budc_code=budc_code and lpco_cade_code=p_categ
                   and budc_papp_ref=papp_ref and papp_vers_code=p_version_sec
                   and papp_pro_id=p_prog;
 begin
   open c_mont_annee;
   fetch c_mont_annee into p_mont_n1;
   close c_mont_annee;

   open c_mont;
   fetch c_mont into p_mont_n2, p_mont_n3;
   close c_mont;
 end p_evol_credits_saisie;
