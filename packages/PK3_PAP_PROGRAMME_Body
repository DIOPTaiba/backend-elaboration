procedure f_rejet_pap(p_papp varchar2, p_foncact varchar2, P_ETAT out number, P_ERREUR out varchar2) IS
  begin
      UPDATE TB_PAP_PROGRAMME SET papp_stat_cod = 'PAPP_2D',
      papp_foncact_id = p_foncact
      WHERE papp_ref = p_papp;
      P_ETAT := 0;
      P_ERREUR := 'Rejet effectue';
  EXCEPTION
   when others then
       P_ERREUR  := Sqlerrm;
       P_ETAT := 1;
END f_rejet_pap;

