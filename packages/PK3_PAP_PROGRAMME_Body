            p_BUDC_CODE  varchar(12);
            p_budc_vers_code varchar(10);
            p_budc_cop_id varchar(10);
            p_budc_foncact_id varchar(10);


             --------------------------------- recuperation des TB_LIGNE_PROJECTION_COMP precedent
            cursor c_ligne_projection_comp_prec(p_lpco_budc_code varchar2) is select LPCO_CODE, LPCO_CADE_CODE, LPCO_MONT_1, LPCO_MONT_2,
            LPCO_MONT_3, LPCO_FONCACT_ID, LPCO_SFIN_CODE  from TB_LIGNE_PROJECTION_COMP where LPCO_BUDC_CODE = p_lpco_budc_code;
