Function f_is_papp_valide(p_papp varchar2) return number is
/*cette fonction renvoie 1 si le PAPP est valide, 0 sinon*/
  cursor c_recherche is select papp_stat_cod from tb_pap_programme where papp_ref=p_papp;
  v_val varchar2(10);
begin
  open c_recherche;
  fetch c_recherche into v_val;
