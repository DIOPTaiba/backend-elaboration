function f_validation_pap_dppd(p_dppd varchar2, p_foncact varchar2, P_ERREUR out varchar2) return number IS
  begin
      UPDATE TB_PAP_PROGRAMME SET papp_stat_cod = 'PAPP_3V',
      papp_foncact_id = p_foncact
      WHERE papp_dppd_ref = p_dppd;
      P_ERREUR := 'Validation effectuee';
      return 0;
  EXCEPTION
   when others then
       P_ERREUR  := Sqlerrm;
       return 1;
END f_validation_pap_dppd;
