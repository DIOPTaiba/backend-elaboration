function get_papp_prec(p_papp varchar2) return varchar2 is
/*Pour un pap de programme donnee, cette fonction renvoie le code du pap precedent*/

  cursor c_pap_courant is select papp_dppd_ref, papp_pro_id
         from tb_pap_programme where papp_ref=p_papp;

  v_dppd_ref varchar2(10);
  --v_vers_code varchar2(10);
  v_pro_id varchar2(10);

  --retrouver le PAP d'avant
  cursor c_papp_prec(p_dppd_code_prec varchar2, p_pro_id varchar2) is
          select papp_ref from tb_pap_programme
          where papp_dppd_ref=p_dppd_code_prec and papp_pro_id=p_pro_id;

  v_code_dppd_prec varchar2(10);
  v_papp_prec varchar2(10);

  begin
    open c_pap_courant;
    fetch c_pap_courant into v_dppd_ref, v_pro_id;
    if c_pap_courant%notfound then
       close c_pap_courant;
       return null;
    end if;
    close c_pap_courant;

    v_code_dppd_prec:=pk3_dppd.get_dppd_prec(v_dppd_ref);

    if v_code_dppd_prec is null then --cas ou le DPPD precedent est null
       return null;
    else
       open c_papp_prec(v_code_dppd_prec,v_pro_id);
        fetch c_papp_prec into v_papp_prec;
        close c_papp_prec;
        return v_papp_prec;
    end if;
end get_papp_prec;
