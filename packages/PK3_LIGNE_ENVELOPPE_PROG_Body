function f_get_levp_num(p_pro_id in tb_programme.pro_id%type,
                        p_vers_code in tb_version_sec.vers_code%type,
                        p_cade_code in tb_categorie_depense.cade_code%type) return tb_ligne_enveloppe_prog.levp_num%type is
cursor C1 is select levp_num from tb_enveloppe_prog a, tb_ligne_enveloppe_prog b
             where a.envp_code=b.levp_envp_code
              and a.envp_vers_code=p_vers_code
              and a.envp_pro_id=p_pro_id
              and b.levp_cade_code=p_cade_code;
v_levp_num tb_ligne_enveloppe_prog.levp_num%type;
begin
  open C1;
  fetch C1 into v_levp_num;
  close C1;
  return v_levp_num;
end f_get_levp_num;
