PROCEDURE p_montant_env_precedente(
   p_prog in varchar2
  ,p_section in varchar2
  ,p_vers_code in varchar2
  ,p_cade_code in varchar2
  ,p_LEVP_MONT_1 out tb_ligne_enveloppe_prog.LEVP_MONT_1%TYPE
  ,p_LEVP_MONT_2 out tb_ligne_enveloppe_prog.LEVP_MONT_2%TYPE
  ,p_LEVP_MONT_3 out tb_ligne_enveloppe_prog.LEVP_MONT_3%TYPE) AS
  BEGIN
    select c.levp_mont_1,c.levp_mont_2,c.levp_mont_3
    into p_LEVP_MONT_1,p_LEVP_MONT_2,p_LEVP_MONT_3
   from tb_version_sec a,tb_enveloppe_prog b,tb_ligne_enveloppe_prog c
   where  b.envp_vers_code=a.vers_code
   and b.envp_code=c.levp_envp_code
   and b.envp_pro_id=p_prog
   and b.envp_sec_id=p_section
   and c.LEVP_CADE_CODE=p_cade_code
   and a.vers_code=PK3_VERSION_SEC.f_get_version_prec(p_vers_code);
   exception
   when others then
   p_LEVP_MONT_1 :=0;
   p_LEVP_MONT_2 := 0;
   p_LEVP_MONT_3 := 0;
 END p_montant_env_precedente;


FUNCTION p_env_prog_par_cade(p_prog in varchar2
                             ,p_section in varchar2
                             ,p_cade_code in varchar2) return number is


--recuperer le montant de l'enveloppe du prog par cade
  cursor c_montant is select LEVP_MONT_1 from tb_ligne_enveloppe_prog, tb_enveloppe_prog
   where LEVP_ENVP_CODE=ENVP_CODE
   and ENVP_SEC_ID=p_section
   and LEVP_CADE_CODE=p_cade_code
   and ENVP_PRO_ID=p_prog;
  v_val number;

begin

        open c_montant ;
        fetch c_montant into v_val;
               if c_montant%notfound then
             close c_montant;
             return 0;
          end if;
        close c_montant;
  return (v_val);
   exception
   when others then
  return 0;
 END p_env_prog_par_cade;
