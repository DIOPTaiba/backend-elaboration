/*
privileges: PPPB04 = peut saisir
PPPB05=transmettre
PPPB06=valider

*/
function f_ptil_saisir (p_expb varchar2, p_foncact varchar2,
                        p_prog varchar2, p_cade varchar2) return number is
/*cette fonction renvoie 1 si l'acteur a le privilege PPPB01, renvoie 0 sinon*/
  v_val number;
begin
  return 1;
  v_val := PK3_PRIVILEGE_PPPB.f_get_priv_sur_prog(p_expb, p_foncact, p_prog, p_cade, 'PPPB04');
  return v_val;
end f_ptil_saisir;
