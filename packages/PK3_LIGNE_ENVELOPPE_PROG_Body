PROCEDURE p_update_plafonds(P_LEVP_NUM number,
                            P_CADE_CODE varchar2,
                            P_MONT_1 number,
                            P_MONT_2 number,
                            P_MONT_3 number,
                            P_MONT_AE_1 number,
                            P_MONT_AE_2 number,
                            P_MONT_AE_3 number,
                            p_FONCACT varchar2,
                            p_etat OUT BOOLEAN,
                            p_erreur OUT VARCHAR2) IS
/*cette procedure fait la maj des montants annuels par categorie depense        */

   cursor c_verif is select envp_code, envs_expb_code expb_code, envp_pro_id
                     from tb_enveloppe_sec, tb_enveloppe_prog, tb_ligne_enveloppe_prog
                     where envs_code=envp_envs_code
                     and envp_code=levp_envp_code
                     and levp_num=P_LEVP_NUM;

v_expb varchar2(10);
v_pro_id varchar(10);
v_envp_code varchar(10);
BEGIN

     /*p_etat:=false;
     p_erreur:='L''enveloppe de programme est verrouillée';
     return;*/


  open c_verif;
  fetch c_verif into v_envp_code, v_expb, v_pro_id;
  if c_verif%notfound then
     p_etat:=false;
     p_erreur:='La reference de l''envoppe de programme n''est pas valide';
     return;
  end if;

  --verifier si l'enveloppe est modifiable:
  /*if pk3_enveloppe_prog.f_is_env_modifiable(v_envp_code)=0 then
      p_etat := false;
      p_erreur  := 'Le statut actuel de l''enveloppe ne permet pas la mise a jour des plafonds';
      return;
  end if;*/ -- à remmettre

  --verifier si l'acteur est habilite
  if f_ptil_saisir (v_expb, p_foncact, v_pro_id, P_CADE_CODE)=0 then
      p_etat := false;
      p_erreur := 'Vos privileges sur la categorie de depense '||P_CADE_CODE||' ne suffisent pas pour la mise a jour des plafonds';
      return;
  end if;

  /*
          if :VB3_LIGNE_ENVELOPPE_SEC.LEVS_DISPO_1<0 or :VB3_LIGNE_ENVELOPPE_SEC.LEVS_DISPO_2<0 or :VB3_LIGNE_ENVELOPPE_SEC.LEVS_DISPO_3<0 then
                    PB3_VALID_ROLLBACK;
                 Bell;
                 v_num := PK_COMMUN.F_AFFICHE_ALERT('alert_stop', 'S', 'Echec : Le plafond de l''enveloppe de la section ne peut etre depassee sur la categorie de depense '||:VB3_LIGNE_ENVELOPPE_SEC.levs_cade_code||'. Revoir la repartition de l''enveloppe de section dans les differents programmes!');
                  first_record;
                 return; --fin
          end if;
  */

  Update tb_ligne_enveloppe_prog
  Set LEVP_MONT_1 = P_MONT_1   ,
      LEVP_MONT_2 = P_MONT_2   ,
      LEVP_MONT_3 = P_MONT_3   ,
      LEVP_MONT_AE1 = P_MONT_AE_1,
      LEVP_MONT_AE2 = P_MONT_AE_2,
      LEVP_MONT_AE3 = P_MONT_AE_3
  Where LEVP_NUM = P_LEVP_NUM;
   p_etat := true;

   exception
     when others then
          p_etat := false;
          p_erreur  := Sqlerrm;
END p_update_plafonds;

