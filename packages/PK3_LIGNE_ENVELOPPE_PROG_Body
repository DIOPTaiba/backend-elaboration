function f_env_annuelle(p_expb_code varchar2, p_levp varchar2, p_annee number) return number is
   /*cette fonction renvoie le montant sur la ligne d'enveloppe pour l'annee consideree*/
  cursor c_exe is select expb_exe from tb_exercice_projet_bud
              where expb_code=p_expb_code;
v_exe number;
v_levp_mont_1 number;
v_levp_mont_2 number;
v_levp_mont_3 number;
begin
  open c_exe;
  fetch c_exe into v_exe;
  if c_exe%notfound then
     close c_exe;
     return null;
  end if;
  close c_exe;

  p_mont_triennale(p_levp, v_levp_mont_1, v_levp_mont_2, v_levp_mont_3);
  if p_annee=v_exe then
     return v_levp_mont_1;
  elsif p_annee=v_exe+1 then
     return v_levp_mont_2;
  elsif p_annee=v_exe+2 then
     return v_levp_mont_3;
  else
     return null;
  end if;
end f_env_annuelle;

