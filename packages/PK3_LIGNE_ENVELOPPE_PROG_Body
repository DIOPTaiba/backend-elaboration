  PROCEDURE p_insertion(p_LEVP_NUM out tb_ligne_enveloppe_prog.levp_num%TYPE, p_LEVP_CADE_CODE in tb_ligne_enveloppe_prog.LEVP_CADE_CODE%TYPE,
            p_LEVP_MONT_1 in tb_ligne_enveloppe_prog.LEVP_MONT_1%TYPE,
            p_LEVP_MONT_2 in tb_ligne_enveloppe_prog.LEVP_MONT_2%TYPE,
            p_LEVP_MONT_3 in tb_ligne_enveloppe_prog.LEVP_MONT_3%TYPE,
            p_LEVP_CONT_1 in tb_ligne_enveloppe_prog.LEVP_CONT_1%TYPE,
            p_LEVP_CONT_2 in tb_ligne_enveloppe_prog.LEVP_CONT_2%TYPE,
            p_LEVP_CONT_3 in tb_ligne_enveloppe_prog.LEVP_CONT_3%TYPE,
            p_LEVP_ENVP_CODE in tb_ligne_enveloppe_prog.LEVP_ENVP_CODE%TYPE,
            p_LEVP_CUMUL_MONT in tb_ligne_enveloppe_prog.LEVP_CUMUL_MONT%TYPE,
            p_LEVP_CUMUL_CONT_COP_1 in tb_ligne_enveloppe_prog.LEVP_CUMUL_CONT_COP_1%TYPE,
            p_LEVP_CUMUL_CONT_COP_2 in tb_ligne_enveloppe_prog.LEVP_CUMUL_CONT_COP_2%TYPE,
            p_LEVP_CUMUL_CONT_COP_3 in tb_ligne_enveloppe_prog.LEVP_CUMUL_CONT_COP_3%TYPE,
            p_LEVP_BUD_CP in tb_ligne_enveloppe_prog.LEVP_BUD_CP%TYPE,
            p_LEVP_CUMUL_PRJECT_1 in tb_ligne_enveloppe_prog.LEVP_CUMUL_PRJECT_1%TYPE,
            p_LEVP_CUMUL_PRJECT_2 in tb_ligne_enveloppe_prog.LEVP_CUMUL_PRJECT_2%TYPE,
            p_LEVP_CUMUL_PRJECT_3 in tb_ligne_enveloppe_prog.LEVP_CUMUL_PRJECT_3%TYPE,
            p_LEVP_LEVS_CODE in tb_ligne_enveloppe_prog.levp_levs_code%TYPE,
            p_etat out boolean, p_erreur out varchar2) AS

            cursor c_sequence_levo_num is select levp_num_seq.NEXTVAL from dual;

            BEGIN
              p_etat := true;

              open c_sequence_levo_num;
              fetch c_sequence_levo_num into p_LEVP_NUM;
              close c_sequence_levo_num;

              insert into tb_ligne_enveloppe_prog(LEVP_NUM, LEVP_CADE_CODE, LEVP_MONT_1, LEVP_MONT_2, LEVP_MONT_3,
                                                LEVP_CONT_1, LEVP_CONT_2, LEVP_CONT_3, LEVP_ENVP_CODE, LEVP_CUMUL_MONT, LEVP_CUMUL_CONT_COP_1, LEVP_CUMUL_CONT_COP_2,
                                                LEVP_CUMUL_CONT_COP_3, LEVP_BUD_CP, LEVP_CUMUL_PRJECT_1, LEVP_CUMUL_PRJECT_2, LEVP_CUMUL_PRJECT_3, LEVP_LEVS_CODE)
              values(p_LEVP_NUM, p_LEVP_CADE_CODE,
              p_LEVP_MONT_1, p_LEVP_MONT_2, p_LEVP_MONT_3,
              p_LEVP_CONT_1, p_LEVP_CONT_2, p_LEVP_CONT_3,
              p_LEVP_ENVP_CODE, p_LEVP_CUMUL_MONT,
              p_LEVP_CUMUL_CONT_COP_1, p_LEVP_CUMUL_CONT_COP_2, p_LEVP_CUMUL_CONT_COP_3,
              p_LEVP_BUD_CP,
              p_LEVP_CUMUL_PRJECT_1, p_LEVP_CUMUL_PRJECT_2, p_LEVP_CUMUL_PRJECT_3, p_LEVP_LEVS_CODE);

              EXCEPTION
                    when others then
                          P_ETAT := false;
                          P_ERREUR  := Sqlerrm;
                          p_LEVP_NUM := 0;
            END p_insertion;
